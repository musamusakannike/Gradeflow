{
  "compilerOptions": {
    /* Core */
    "target": "ES2020",
    "module": "CommonJS",

    /* Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Interop & Compatibility */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Safety */
    "strict": true,
    "skipLibCheck": true,

    /* Node Environment */
    "types": ["node"],

    /* DX (Developer Experience) */
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}