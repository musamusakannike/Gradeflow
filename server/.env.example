# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gradeflow

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=gradeflow
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# Resend (Email)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@gradeflow.com

# Paystack (Payments - Nigeria)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# Firebase (Google Auth)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Expo (Push Notifications)
EXPO_ACCESS_TOKEN=your-expo-access-token

# App
APP_NAME=GradeFlow
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Super Admin (Initial Setup)
SUPER_ADMIN_EMAIL=admin@gradeflow.com
SUPER_ADMIN_PASSWORD=SuperSecurePassword123!
